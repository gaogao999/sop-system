# --- SOP system configuration -------------------------------------------------
# Copy to `.env` and adjust. Never commit the real `.env` (it is git-ignored).
# All values below are optional; the defaults shown let the app run as-is.

# HTTP port
PORT=3000

# Where the SQLite database and uploaded files live. On a server, point these
# at a persistent path/volume (e.g. /data) so nothing is lost on restart.
DB_PATH=data/sop.db
UPLOAD_DIR=uploads

# Session signing key — ALWAYS set a long random value in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Initial admin account, created on first run only.
ADMIN_USER=admin
ADMIN_PASS=admin123

# Production hardening: set NODE_ENV=production and TRUST_PROXY=1 when running
# behind an HTTPS reverse proxy (enables Secure cookies + proxy trust).
NODE_ENV=
TRUST_PROXY=

# OCR for scanned / image-only PDFs (needs poppler-utils + tesseract-ocr).
# OCR_LANG: tesseract languages, e.g. "eng" or "eng+tha" for Thai documents.
# OCR_MAX_PAGES: cap on pages OCR'd per upload (keeps uploads responsive).
OCR_LANG=eng
OCR_MAX_PAGES=20

# Authentication mode.
#   local    = built-in user table (bcrypt) — the default / development mock.
#   upstream = delegate to the shared company /checklogin (NOT yet wired;
#              needs the confirmed endpoint contract before enabling).
AUTH_MODE=local
# AUTH_UPSTREAM_URL=http://172.19.27.7:3018/checklogin
